<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ua.lpnu.deposits.ui.DepositListController"
      spacing="0"
      maxWidth="Infinity" maxHeight="Infinity"
      style="-fx-background-color: #f0f4f8;">

    <!-- Action toolbar -->
    <HBox styleClass="content-toolbar" alignment="CENTER_LEFT" spacing="8"
          style="-fx-background-color: white; -fx-padding: 10 16; -fx-border-color: transparent transparent #e2e8f0 transparent; -fx-border-width: 0 0 1 0;">
        <Button fx:id="addButton" text="➕  Додати" onAction="#onAdd" styleClass="primary-button"/>
        <Button fx:id="editButton"   text="✏  Редагувати" onAction="#onEdit"
                disable="true"/>
        <Button fx:id="deleteButton" text="🗑  Видалити"   onAction="#onDelete"
                disable="true" styleClass="danger-button"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="↺  Оновити" onAction="#onRefresh"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="depositTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: white; -fx-border-width: 0; -fx-padding: 0 16 0 16;">
        <columns>
            <TableColumn fx:id="nameColumn"         text="Назва"            prefWidth="200"/>
            <TableColumn fx:id="bankColumn"         text="Банк"             prefWidth="150"/>
            <TableColumn fx:id="typeColumn"         text="Тип"              prefWidth="120"/>
            <TableColumn fx:id="currencyColumn"     text="Валюта"           prefWidth="75"/>
            <TableColumn fx:id="minAmountColumn"    text="Мін. сума"        prefWidth="110"/>
            <TableColumn fx:id="interestRateColumn" text="Ставка %"         prefWidth="90"/>
            <TableColumn fx:id="termMonthsColumn"   text="Термін"           prefWidth="110"/>
            <TableColumn fx:id="canWithdrawColumn"  text="Дострок. зняття"  prefWidth="130"/>
            <TableColumn fx:id="canReplenishColumn" text="Поповнення"       prefWidth="110"/>
        </columns>
        <placeholder>
            <Label text="Депозити відсутні. Натисніть «➕ Додати» для створення."
                   style="-fx-text-fill: #9ca3af;"/>
        </placeholder>
    </TableView>

    <!-- Status bar -->
    <HBox style="-fx-background-color: white; -fx-padding: 8 16; -fx-border-color: #e2e8f0 transparent transparent transparent; -fx-border-width: 1 0 0 0;">
        <Label fx:id="countLabel" styleClass="count-label"/>
    </HBox>

</VBox>
