<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ua.lpnu.deposits.ui.DepositFormController"
      spacing="0"
      style="-fx-background-color: white;">

    <!-- Header bar -->
    <HBox styleClass="form-header"
          style="-fx-background-color: #1e2d4f; -fx-padding: 16 24;">
        <Label fx:id="formTitleLabel" text="Депозит"
               style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Form body -->
    <VBox style="-fx-padding: 24; -fx-spacing: 0; -fx-background-color: white;"
          VBox.vgrow="ALWAYS">

        <GridPane hgap="16" vgap="14">
            <columnConstraints>
                <ColumnConstraints minWidth="155" prefWidth="165"/>
                <ColumnConstraints minWidth="240" prefWidth="280" hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Назва -->
            <Label text="Назва:" styleClass="form-label"
                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="nameField" promptText="Введіть назву депозиту"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <!-- Банк -->
            <Label text="Банк:" styleClass="form-label"
                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="bankComboBox" maxWidth="Infinity"
                      GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <!-- Клієнт -->
            <Label text="Клієнт:" styleClass="form-label"
                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox fx:id="clientComboBox" maxWidth="Infinity"
                      GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <!-- Сума вкладу -->
            <Label text="Сума вкладу:" styleClass="form-label"
                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="depositAmountField" promptText="Введіть суму вкладу"
                       disable="true"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <!-- Тип депозиту -->
            <Label text="Тип депозиту:" styleClass="form-label"
                   GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <ComboBox fx:id="typeComboBox" maxWidth="Infinity"
                      GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <!-- Валюта -->
            <Label text="Валюта:" styleClass="form-label"
                   GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <TextField fx:id="currencyField" promptText="UAH"
                       GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <!-- Мінімальна сума -->
            <Label text="Мін. сума:" styleClass="form-label"
                   GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <TextField fx:id="minAmountField" promptText="0.00"
                       GridPane.rowIndex="6" GridPane.columnIndex="1"/>

            <!-- Річна ставка -->
            <Label text="Річна ставка (%):" styleClass="form-label"
                   GridPane.rowIndex="7" GridPane.columnIndex="0"/>
            <TextField fx:id="interestRateField" promptText="0.00"
                       GridPane.rowIndex="7" GridPane.columnIndex="1"/>

            <!-- Термін (прихований для DEMAND) -->
            <Label fx:id="termLabel" text="Термін (місяці):" styleClass="form-label"
                   GridPane.rowIndex="8" GridPane.columnIndex="0"/>
            <TextField fx:id="termMonthsField" promptText="12"
                       GridPane.rowIndex="8" GridPane.columnIndex="1"/>

            <!-- Штраф (лише для TERM) -->
            <Label fx:id="penaltyLabel" text="Штраф за дострокове (%):" styleClass="form-label"
                   GridPane.rowIndex="9" GridPane.columnIndex="0"/>
            <TextField fx:id="penaltyRateField" promptText="0.00"
                       GridPane.rowIndex="9" GridPane.columnIndex="1"/>

            <!-- Features info -->
            <Label text="Можливості:" styleClass="form-label"
                   GridPane.rowIndex="10" GridPane.columnIndex="0"/>
            <Label fx:id="featuresLabel" text="" wrapText="true"
                   style="-fx-text-fill: #6b7c9d; -fx-font-size: 12px;"
                   GridPane.rowIndex="10" GridPane.columnIndex="1"/>
        </GridPane>

    </VBox>

    <!-- Footer buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT"
          style="-fx-background-color: #f8fafc; -fx-padding: 14 24; -fx-border-color: #e2e8f0 transparent transparent transparent; -fx-border-width: 1 0 0 0;">
        <Button text="Скасувати" onAction="#onCancel" cancelButton="true"/>
        <Button fx:id="saveButton" text="💾  Зберегти" onAction="#onSave"
                styleClass="primary-button" defaultButton="true"/>
    </HBox>

</VBox>
