<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ua.lpnu.deposits.ui.ClientListController"
      spacing="0"
      maxWidth="Infinity" maxHeight="Infinity"
      style="-fx-background-color: #f0f4f8;">

    <!-- Action toolbar -->
    <HBox styleClass="content-toolbar" alignment="CENTER_LEFT" spacing="8"
          style="-fx-background-color: white; -fx-padding: 10 16; -fx-border-color: transparent transparent #e2e8f0 transparent; -fx-border-width: 0 0 1 0;">
        <Button fx:id="addButton" text="➕  Додати клієнта" onAction="#onAdd" styleClass="primary-button"/>
        <Button fx:id="editButton"         text="✏  Редагувати" onAction="#onEdit"   disable="true"/>
        <Button fx:id="deleteButton"       text="🗑  Видалити"   onAction="#onDelete" disable="true"
                styleClass="danger-button"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="🔍  Прізвище..."
                   prefWidth="220" onAction="#onSearch"
                   style="-fx-background-color: #f8fafc; -fx-border-color: #d1d5db; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12;"/>
        <Button text="Знайти"   onAction="#onSearch"/>
        <Button text="↺  Оновити" onAction="#onRefresh"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="clientTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: white; -fx-border-width: 0; -fx-padding: 0 16 0 16;">
        <columns>
            <TableColumn fx:id="idColumn"        text="ID"        prefWidth="60"/>
            <TableColumn fx:id="lastNameColumn"  text="Прізвище"  prefWidth="200"/>
            <TableColumn fx:id="firstNameColumn" text="Ім'я"      prefWidth="180"/>
            <TableColumn fx:id="emailColumn"     text="Email"     prefWidth="260"/>
        </columns>
        <placeholder>
            <Label text="Клієнти відсутні. Натисніть «➕ Додати клієнта» для створення."
                   style="-fx-text-fill: #9ca3af;"/>
        </placeholder>
    </TableView>

    <!-- Status bar -->
    <HBox style="-fx-background-color: white; -fx-padding: 8 16; -fx-border-color: #e2e8f0 transparent transparent transparent; -fx-border-width: 1 0 0 0;">
        <Label fx:id="countLabel" styleClass="count-label"/>
    </HBox>

</VBox>
